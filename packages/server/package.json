{
  "name": "@knightcode/server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "db:migrate:deploy": "bun run --cwd ../database db:migrate:deploy",
    "postinstall": "bun run --cwd ../database db:generate"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.68",
    "@ai-sdk/openai": "^3.0.52",
    "@hono/zod-validator": "^0.8.0",
    "@knightcode/database": "workspace:*",
    "@knightcode/shared": "workspace:*",
    "@openrouter/ai-sdk-provider": "^2.9.0",
    "@sentry/bun": "^10.53.1",
    "@sentry/hono": "^10.53.1",
    "ai": "^6.0.154",
    "dotenv": "^17.4.2",
    "hono": "^4.12.22",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@repo/typescript-config": "workspace:*"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
